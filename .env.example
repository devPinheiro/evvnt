NODE_ENV=development
PORT=4000

# Public URL for links in auth emails (verification, password reset). Defaults to http://localhost:4000
# APP_PUBLIC_URL="https://api.yourdomain.com"

# Postgres (install locally, e.g. brew install postgresql@16; start the server)
# Create databases: createdb evvnt && createdb evvnt_e2e
# Match user/password to your install (peer auth often works: postgresql://localhost:5432/evvnt?schema=public)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/evvnt?schema=public"

# Auth
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# Paystack (required when enabling payments webhooks)
PAYSTACK_SECRET_KEY="sk_test_xxx"

# SMTP — Mailgun (recommended) or any SMTP provider
# US:  SMTP_HOST=smtp.mailgun.org
# EU:  SMTP_HOST=smtp.eu.mailgun.org
# SMTP_USER = full "postmaster@mg.yourdomain.com" from Mailgun → Sending → SMTP credentials
# SMTP_PASS = SMTP password (not the API key)
# EMAIL_FROM must use a sender/domain you verified in Mailgun
# SMTP_PORT defaults to 587 (STARTTLS) if omitted
SMTP_HOST="smtp.mailgun.org"
SMTP_PORT=587
SMTP_USER="postmaster@mg.yourdomain.com"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="Evvnt <no-reply@yourdomain.com>"
