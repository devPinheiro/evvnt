# Copy to `.env.test` and adjust. Used by Vitest (`test/setup.ts`) with override on top of `.env`.
# Use a dedicated database for E2E — tests TRUNCATE all rows in Organisation + PaymentEvent trees.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/evvnt_e2e?schema=public"

# Required for Paystack webhook E2E (any string; must match runtime env when signing test payloads)
PAYSTACK_SECRET_KEY="test-paystack-secret-key-32chars!!"
