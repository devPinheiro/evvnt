{
  "info": {
    "_postman_id": "a1b2c3d4-evvnt-api-v1",
    "name": "Evvnt API v1",
    "description": "Import alongside environment or set collection variables: `baseUrl` (e.g. http://localhost:4000), `accessToken` (Bearer from login/signup). Optional: `eventId`, `guestId`, `vendorId`, `assetId`, `rsvpToken`.\n\nOpenAPI: `GET {{baseUrl}}/api/openapi.json` · Swagger UI: `{{baseUrl}}/api/docs`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "accessToken", "value": "" },
    { "key": "orgId", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "guestId", "value": "" },
    { "key": "vendorId", "value": "" },
    { "key": "assetId", "value": "" },
    { "key": "rsvpToken", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/v1/auth/signup",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orgName\": \"My Org\",\n  \"email\": \"you@example.com\",\n  \"password\": \"password12\",\n  \"name\": \"You\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/signup"
          }
        },
        {
          "name": "POST /api/v1/auth/login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orgId\": \"{{orgId}}\",\n  \"email\": \"you@example.com\",\n  \"password\": \"password12\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "POST /api/v1/auth/refresh",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"<paste refresh token>\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/refresh"
          }
        },
        {
          "name": "POST /api/v1/auth/logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"<paste refresh token>\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/logout"
          }
        },
        {
          "name": "GET /api/v1/auth/me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        }
      ]
    },
    {
